rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sites/{site_id} {
      // Allow general read-only access to structural collections
      allow read: if true;
      
      // Helper function to check if the current user is an authenticated administrator
      function isAdmin() {
        return request.auth != null && 
          (request.auth.token.email == 'iwayanpastika147@gmail.com' || 
           request.auth.token.email == 'saputra.developer@gmail.com' ||
           request.auth.token.email == 'test@example.com');
      }

      match /config/{document} {
        allow read: if true;
        allow write: if isAdmin();
      }
      
      match /gallery/{document} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /announcements/{document} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /liveVisitors/{document} {
        allow read, write: if true;
      }

      match /guestbook/{document} {
        allow read, create: if true;
        // Allow updates only if the 'likesCount' field is updated, OR if the user is an admin
        allow update: if isAdmin() || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount'])
        );
        allow delete: if isAdmin();
      }

      match /rsvp/{document} {
        allow read, create: if true;
        allow update, delete: if isAdmin();
      }
    }
  }
}
