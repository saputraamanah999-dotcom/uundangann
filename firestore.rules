rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sites/{site_id} {
      // Allow all read access
      allow read: if true;

      // Helper function to check if the current user is an authenticated administrator
      function isAdmin() {
        return request.auth != null &&
          (request.auth.token.email == 'iwayanpastika147@gmail.com' ||
           request.auth.token.email == 'saputra.developer@gmail.com' ||
           request.auth.token.email == 'test@example.com');
      }

      match /config/{document} {
        allow read: if true;
        allow write: if true; // Temporarily open for auto-seeding
      }

      match /gallery/{document} {
        allow read: if true;
        allow write: if true; // Temporarily open for auto-seeding
      }

      match /announcements/{document} {
        allow read: if true;
        allow write: if true; // Temporarily open for auto-seeding
      }

      match /liveVisitors/{document} {
        allow read, write: if true;
      }

      match /guestbook/{document} {
        allow read, create: if true;
        allow update: if isAdmin() || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount'])
        );
        allow delete: if isAdmin();
      }

      match /rsvp/{document} {
        allow read, create: if true;
        allow update, delete: if isAdmin();
      }

      match /fcmTokens/{document} {
        allow read, write: if true;
      }
    }
  }
}